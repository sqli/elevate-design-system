{
  "extends": ["stylelint-config-standard"],
  "plugins": ["stylelint-order"],
  "ignoreFiles": [
    "dist/**/*",
    "src/css/tokens/_colors.css",
    ".storybook/preview.css",
    "src/css/main.css",
    "src/css/_fonts.css",
    "src/css/_tokens.css",
    "src/css/_themes.css",
    "src/css/_customizations.css",
    "src/css/_utilities.css"
  ],
  "rules": {
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "tailwind",
          "apply",
          "layer",
          "config",
          "theme",
          "utility",
          "custom-variant"
        ]
      }
    ],
    "function-no-unknown": [
      true,
      {
        "ignoreFunctions": ["theme", "rgb"]
      }
    ],
    "selector-class-pattern": [
      "^(sqli-[a-z0-9]+(-[a-z0-9]+)*(__[a-z0-9]+(-[a-z0-9]+)*)?(--[a-z0-9]+(-[a-z0-9]+)*)?|dark|light|mermaid|node|nodeLabel|edgeLabel|edgePath|flowchart-link|cluster|actor|actor-line|messageLine[0-9]|messageText|note|noteText|activation[0-9]|loopText|loopLine|labelBox|labelText|classGroup|statediagram-state|state-start|state-end|stateGroup|stateLabel|label-container|label|relation|cardinality|marker|hljs[a-z-]*|token|language-[a-z]+|prose|prose-[a-z]+|markdown-body|col-span-[0-9]+|grid-cols-[0-9]+|key-figure-[a-z]+|is-[a-z]+)$",
      {
        "message": "Les classes doivent suivre BEM avec préfixe sqli- (ex: sqli-block__element--modifier)"
      }
    ],
    "custom-property-pattern": null,
    "no-descending-specificity": null,

    "order/order": ["custom-properties", "dollar-variables", "declarations", "rules", "at-rules"],
    "order/properties-order": [
      {
        "groupName": "position",
        "properties": ["position", "top", "right", "bottom", "left", "z-index"]
      },
      {
        "groupName": "display",
        "properties": [
          "display",
          "flex",
          "flex-direction",
          "flex-wrap",
          "flex-flow",
          "flex-grow",
          "flex-shrink",
          "flex-basis",
          "justify-content",
          "align-items",
          "align-content",
          "align-self",
          "order",
          "grid",
          "grid-template",
          "grid-template-columns",
          "grid-template-rows",
          "grid-template-areas",
          "grid-auto-columns",
          "grid-auto-rows",
          "grid-auto-flow",
          "grid-column",
          "grid-row",
          "grid-area",
          "gap",
          "row-gap",
          "column-gap"
        ]
      },
      {
        "groupName": "box-model",
        "properties": [
          "box-sizing",
          "width",
          "min-width",
          "max-width",
          "height",
          "min-height",
          "max-height",
          "margin",
          "margin-top",
          "margin-right",
          "margin-bottom",
          "margin-left",
          "padding",
          "padding-top",
          "padding-right",
          "padding-bottom",
          "padding-left",
          "overflow",
          "overflow-x",
          "overflow-y"
        ]
      },
      {
        "groupName": "typography",
        "properties": [
          "font",
          "font-family",
          "font-size",
          "font-weight",
          "font-style",
          "line-height",
          "letter-spacing",
          "text-align",
          "text-decoration",
          "text-transform",
          "white-space",
          "word-break",
          "word-wrap",
          "color"
        ]
      },
      {
        "groupName": "visual",
        "properties": [
          "background",
          "background-color",
          "background-image",
          "background-position",
          "background-repeat",
          "background-size",
          "border",
          "border-width",
          "border-style",
          "border-color",
          "border-top",
          "border-right",
          "border-bottom",
          "border-left",
          "border-radius",
          "box-shadow",
          "outline",
          "opacity",
          "visibility"
        ]
      },
      {
        "groupName": "animation",
        "properties": [
          "transform",
          "transition",
          "animation",
          "animation-name",
          "animation-duration",
          "animation-timing-function",
          "animation-delay",
          "animation-iteration-count",
          "animation-direction",
          "animation-fill-mode"
        ]
      },
      {
        "groupName": "misc",
        "properties": ["cursor", "pointer-events", "user-select", "appearance", "content"]
      }
    ],

    "color-named": "never",
    "color-no-hex": [
      true,
      {
        "message": "Utilisez les variables CSS --sqli-* au lieu des couleurs hexadécimales (color-no-hex)",
        "severity": "warning"
      }
    ]
  }
}
