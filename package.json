{
  "name": "@sqli/elevate-design-system",
  "version": "0.6.1-alpha",
  "type": "module",
  "description": "Elevate Design System - DaisyUI themes (sqli-light, sqli-dark) for SQLI applications",
  "main": "dist/sqli-design-system.css",
  "style": "dist/sqli-design-system.css",
  "exports": {
    ".": "./dist/sqli-design-system.css",
    "./css": "./dist/sqli-design-system.css",
    "./css/min": "./dist/sqli-design-system.min.css",
    "./tokens": "./dist/tokens.css",
    "./fonts": "./dist/fonts.css",
    "./fonts.css": "./dist/fonts.css",
    "./preset": {
      "types": "./dist/types/preset.d.ts",
      "default": "./src/tailwind/preset.js"
    },
    "./charts": {
      "types": "./dist/types/charts.d.ts",
      "default": "./src/charts/index.js"
    },
    "./assets": {
      "types": "./dist/types/assets.d.ts",
      "default": "./src/assets/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts"
    },
    "./logos/*": "./dist/logos/*",
    "./favicons/*": "./dist/logos/favicon*",
    "./dist/*": "./dist/*"
  },
  "unpkg": "dist/sqli-design-system.min.css",
  "jsdelivr": "dist/sqli-design-system.min.css",
  "files": [
    "dist/",
    "src/tokens/",
    "src/tailwind/",
    "src/charts/",
    "src/assets/",
    "README.md"
  ],
  "scripts": {
    "dev": "concurrently \"npm run watch:css\" \"npm run storybook\"",
    "build": "npm run build:css && npm run build:tokens && npm run build:types && npm run build:fonts-css && npm run build:fonts && npm run build:logos",
    "build:types": "node scripts/generate-types.js",
    "build:css": "postcss ./src/css/main.css -o ./dist/sqli-design-system.css && node scripts/minify-css.js",
    "build:fonts": "cp -r ./assets/fonts ./dist/",
    "build:logos": "cp -r ./assets/logos ./dist/",
    "build:tokens": "node scripts/build-tokens-standalone.js",
    "build:fonts-css": "node scripts/build-fonts-css.js",
    "watch:css": "postcss ./src/css/main.css -o ./dist/sqli-design-system.css --watch",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o storybook-static",
    "lint": "npm run lint:css && npm run lint:js",
    "lint:css": "stylelint 'src/**/*.css'",
    "lint:js": "eslint 'src/**/*.js' 'scripts/**/*.js' 'tests/**/*.js' 'stories/**/*.js' '.storybook/**/*.js'",
    "lint:fix": "npm run lint:css -- --fix && npm run lint:js -- --fix",
    "format": "prettier --check '**/*.{js,json,md,css}'",
    "format:fix": "prettier --write '**/*.{js,json,md,css}'",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest --watch",
    "test:a11y": "npm run build-storybook -- --quiet && axe storybook-static --exit",
    "check:size": "npm run build:css && size-limit",
    "validate": "npm run lint && npm run format && npm run validate:colors && npm run build",
    "validate:colors": "node scripts/validate-colors.js",
    "pre-release": "npm run validate && npm run test -- --run --coverage",
    "analyze": "npm run build:css && size-limit --json",
    "clean": "rm -rf dist/ storybook-static/ .coverage/",
    "reset": "npm run clean && rm -rf node_modules/ package-lock.json && npm install",
    "docs:serve": "npx http-server storybook-static -p 8080",
    "deps:outdated": "npm outdated",
    "deps:security": "npm audit",
    "release": "semantic-release",
    "release:dry-run": "semantic-release --dry-run",
    "prepare": "husky",
    "prepublishOnly": "npm run build"
  },
  "lint-staged": {
    "*.css": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "peerDependencies": {
    "tailwindcss": "^4.1.0",
    "daisyui": "^5.0.0",
    "recharts": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    },
    "daisyui": {
      "optional": true
    },
    "recharts": {
      "optional": true
    }
  },
  "devDependencies": {
    "@axe-core/cli": "^4.11.0",
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@eslint/css": "^0.14.1",
    "@eslint/js": "^9.39.2",
    "@eslint/json": "^0.14.0",
    "@eslint/markdown": "^7.5.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.1",
    "@size-limit/file": "^11.2.0",
    "@storybook/addon-a11y": "^10.1.11",
    "@storybook/addon-docs": "^10.1.11",
    "@storybook/addon-themes": "^10.1.11",
    "@storybook/html-vite": "^10.1.11",
    "@tailwindcss/postcss": "^4.1.0",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "daisyui": "^5.5.14",
    "cssnano": "^7.0.6",
    "cssnano-preset-default": "^7.0.10",
    "eslint": "^9.39.2",
    "eslint-plugin-storybook": "10.1.11",
    "globals": "^16.5.0",
    "heroicons": "^2.2.0",
    "husky": "^9.1.7",
    "jsdom": "^27.0.1",
    "lint-staged": "^16.2.7",
    "mermaid": "^11.12.2",
    "postcss": "^8.4.49",
    "postcss-cli": "^11.0.0",
    "prettier": "^3.7.4",
    "prismjs": "^1.30.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "recharts": "^3.6.0",
    "semantic-release": "^21.1.2",
    "size-limit": "^11.2.0",
    "storybook": "^10.1.11",
    "stylelint": "^16.11.0",
    "stylelint-config-standard": "^36.0.1",
    "stylelint-order": "^7.0.0",
    "tailwindcss": "^4.1.0",
    "vite": "^6.0.3",
    "vitest": "^3.2.4"
  },
  "keywords": [
    "sqli",
    "design-system",
    "tailwindcss",
    "css",
    "components",
    "ui"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sqli/elevate-design-system.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "UNLICENSED",
  "author": "SQLI",
  "dependencies": {},
  "size-limit": [
    {
      "path": "dist/sqli-design-system.min.css",
      "limit": "250 KB"
    },
    {
      "path": "dist/sqli-design-system.css",
      "limit": "300 KB"
    }
  ]
}
